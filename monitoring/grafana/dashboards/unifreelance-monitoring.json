          "expr": "probe_success{job=\"blackbox-cloud\",instance=\"http://gradproject-back-1776705847.francecentral.azurecontainer.io:5000/health\"}",
          "refId": "A"
        }
      ],
      "title": "Azure Health Probe",
      "type": "stat"
